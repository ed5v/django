{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Django (.venv)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\manage.py",
      "args": [
        "runserver",
        "127.0.0.1:8000"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "env": {
        "PYTHONIOENCODING": "utf-8"
      }
    }
  ]
}